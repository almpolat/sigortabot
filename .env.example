# =====================================================
# SigortaBot - Çevre Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve doldurun
# cp .env.example .env
# =====================================================

# --- Google Veo 3.1 Video API (google-genai SDK) ---
VEO_MODEL=veo-3.1-generate-preview
GEMINI_API_KEY=your-gemini-api-key

# --- Anthropic Claude (Script Generation) ---
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Video Üretim Ayarları ---
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_DURATION_SECONDS=8
VIDEO_FPS=24
VIDEO_FORMAT=mp4

# --- Sahne Yapısı (saniye) ---
SCENE_HOOK_START=0
SCENE_HOOK_END=2
SCENE_MAIN_START=2
SCENE_MAIN_END=6
SCENE_PUNCHLINE_START=6
SCENE_PUNCHLINE_END=8

# --- Karakter Kütüphanesi ---
CHARACTERS_DIR=./characters
CHARACTER_STYLE=3D_cartoon_animation

# --- Çıktı Dizini ---
OUTPUT_DIR=./output
SCRIPTS_DIR=./scripts

# --- Otomasyon Ayarları ---
VIDEOS_PER_RUN=5
BATCH_SIZE=1
RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=30

# --- Sosyal Medya (İsteğe Bağlı) ---
# INSTAGRAM_ACCESS_TOKEN=your-instagram-token
# TIKTOK_API_KEY=your-tiktok-api-key
# YOUTUBE_API_KEY=your-youtube-api-key

# --- Loglama ---
LOG_LEVEL=INFO
LOG_FILE=./output/sigortabot.log
